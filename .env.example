# ===== LLM Provider =====
# Options: mock | openrouter
REVIEW_PROVIDER=mock
OPENROUTER_API_KEY=
OPENROUTER_MODEL=qwen/qwen-2.5-coder-32b-instruct:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ===== GitHub OAuth =====
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_WEBHOOK_SECRET=change-me-to-random-string

# ===== Database (Postgres) =====
# Local docker:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/prreviewer
# Prod (Neon): postgresql://user:pass@host/db?sslmode=require

# ===== Redis =====
# Local docker:
REDIS_URL=redis://localhost:6379/0
# Prod (Upstash): rediss://default:pass@host:port

# ===== NextAuth =====
NEXTAUTH_SECRET=change-me-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# ===== Backend =====
BACKEND_URL=http://localhost:8000
PUBLIC_WEBHOOK_URL=http://localhost:8000/webhooks/github
# In prod set PUBLIC_WEBHOOK_URL to https://your-backend.up.railway.app/webhooks/github

# ===== Misc =====
DIFF_MAX_CHARS=32000
LOG_LEVEL=INFO
