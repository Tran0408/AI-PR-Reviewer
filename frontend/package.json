{
  "name": "pr-reviewer-frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "predev": "node -e \"require('fs').mkdirSync('prisma',{recursive:true});require('fs').copyFileSync('../prisma/schema.prisma','prisma/schema.prisma')\" || true",
    "prebuild": "node -e \"require('fs').mkdirSync('prisma',{recursive:true});require('fs').copyFileSync('../prisma/schema.prisma','prisma/schema.prisma')\" || true",
    "build": "prisma generate --schema=./prisma/schema.prisma --generator=client && next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate --schema=./prisma/schema.prisma --generator=client",
    "prisma:migrate": "prisma migrate deploy --schema=./prisma/schema.prisma",
    "prisma:dev": "prisma migrate dev --schema=./prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "clsx": "2.1.1",
    "next": "14.2.15",
    "next-auth": "4.24.10",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tailwind-merge": "2.5.4"
  },
  "devDependencies": {
    "@types/node": "20.16.11",
    "@types/react": "18.3.11",
    "@types/react-dom": "18.3.0",
    "autoprefixer": "10.4.20",
    "eslint": "8.57.1",
    "eslint-config-next": "14.2.15",
    "postcss": "8.4.47",
    "prisma": "5.22.0",
    "tailwindcss": "3.4.14",
    "typescript": "5.6.3"
  }
}
